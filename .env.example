# Copy to .env for Docker Compose or local development.
FILAMENTBRIDGE_PORT=3000
FILAMENTBRIDGE_BASE_URL=http://filamentbridge.local:3000
FILAMENTBRIDGE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
FILAMENTBRIDGE_APP_SECRET=replace-with-a-long-random-local-secret
FILAMENTBRIDGE_DATABASE_PATH=./runtime/filamentbridge.sqlite
FILAMENTBRIDGE_KEY_DIR=./runtime/keys
FILAMENTBRIDGE_BACKUP_DIR=./runtime/backups
FILAMENTBRIDGE_WEB_DIST=./apps/web/dist
FILAMENTBRIDGE_PRINTER_CONNECTOR_ENABLED=true
FILAMENTBRIDGE_BAMBU_MQTT_INSECURE_TLS=false
