{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "types": ["node", "react", "react-dom", "vitest/globals", "@testing-library/jest-dom"],
    "allowImportingTsExtensions": true
  },
  "include": [
    "packages/**/*.ts",
    "apps/server/src/**/*.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/web/vite.config.ts",
    "tests/**/*.ts",
    "vitest.config.ts"
  ]
}
